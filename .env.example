TELEGRAM_BOT_TOKEN=
GEMINI_API_KEY=
ADMIN_ID=
GASTROBAR_GROUP_ID=
SPORTS_API_KEY=

# Event Radar: BetBoom-first (Playwright перехватывает JSON линии)
BETBOOM_USE_PLAYWRIGHT=1
BETBOOM_API_FALLBACK=0
# Опционально: прямой JSON URL линии (если найдёте endpoint в DevTools)
# BETBOOM_JSON_URL=
# RADAR_GEMINI_DISCOVERY=0

# local (Windows) | railway (явно на Railway; иначе авто по RAILWAY_ENVIRONMENT)
RUN_MODE=local

# Football now24: min football_watchability_score (default 55)
# NOW24_FOOTBALL_MIN_WATCHABILITY=55

# Fail-fast, если токен не от Gastrobar (не SpiceSpace и т.п.)
EXPECTED_BOT_USERNAME=gastrobar_nhatrang_bot

# Опционально: путь к SQLite (по умолчанию gastrobar_bot.sqlite3)
# DATABASE_PATH=gastrobar_bot.sqlite3

# Модель Gemini (если не задано на Railway — gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Рабочие часы бара (афиша /events)
BAR_OPEN_TIME=08:00
BAR_CLOSE_TIME=06:00
TIMEZONE=Asia/Ho_Chi_Minh

# Ежедневная рассылка готового поста админу (Asia/Ho_Chi_Minh)
DAILY_POST_HOUR=11

# Авто-афиша недели: четверг 10:40 (0=Пн … 3=Чт)
WEEKLY_RADAR_DOW=3
WEEKLY_RADAR_HOUR=10
WEEKLY_RADAR_MINUTE=40

# Weekly radar: без жёсткого top-N (999 = все выше порога watchability)
RADAR_WEEKLY_MAX=999
RADAR_MIN_WATCHABILITY=32
RADAR_API_FIRST=1
RADAR_API_MIN_SEED=5
NOW24_MAX_ITEMS=50
NOW24_FOOTBALL_MIN_WATCHABILITY=48

# Телевизоров в баре — макс. параллельных эфиров в daily digest / now24
GASTROBAR_TV_COUNT=2
